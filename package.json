{
  "name": "fjallkompis",
  "private": true,
  "version": "0.10.2",
  "type": "module",
  "description": "Fjällkompis — offline-first hut-to-hut trail companion PWA for the Kungsleden (prototype).",
  "scripts": {
    "dev": "npm run generate:route && vite",
    "build": "npm run check:version && npm run generate:route && tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "check:version": "node scripts/check-version-consistency.mjs",
    "generate:route": "node scripts/generate-route-data.mjs",
    "generate:route:kungsleden": "node scripts/generate-route-data.mjs kungsleden",
    "generate:map:satellite": "./scripts/build-satellite-map.sh",
    "test": "npm run check:version && npm run generate:route && node --test 'tests/**/*.test.mjs'"
  },
  "dependencies": {
    "@protomaps/basemaps": "^5.7.2",
    "lucide-react": "^1.23.0",
    "maplibre-gl": "^5.24.0",
    "pmtiles": "^4.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^0.21.1"
  }
}
