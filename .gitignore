node_modules
dist
dist-ssr
*.local

# Real environment files are never committed (API keys). `*.local` above
# already covers .env.local; these cover every other .env variant. The
# tracked template with empty placeholders is .env.example.
.env
.env.*
!.env.example
.DS_Store
.vscode/*
!.vscode/extensions.json
dev-dist
.claude/
*.tsbuildinfo

# Satellite archive: canonical copy is the satellite-data-vN GitHub Release
# asset, injected into the Pages build by deploy.yml — never committed.
public/maps/kungsleden-satellite.pmtiles

# Terrain relief archives: same model — canonical copies live on the
# terrain-data-vN GitHub Release, injected by deploy.yml, never committed.
# Build locally with scripts/build-terrain-map.sh.
public/maps/kungsleden-terrain.pmtiles
public/maps/kungsleden-contours.pmtiles
